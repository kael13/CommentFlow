# ═══════════════════════════════════════════════════════
# CommentFlow — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — only .env.example is tracked.
# ═══════════════════════════════════════════════════════

# ─── OpenRouter LLM API ───────────────────────────────
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_FALLBACK_MODEL=google/gemini-2.0-flash-lite
OPENROUTER_MAX_RETRIES=3
LLM_RATE_LIMIT_RPM=20
LLM_JOB_TIMEOUT_MS=30000

# ─── PostgreSQL Database ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=commentflow
DB_USER=postgres
DB_PASSWORD=change-me-to-a-strong-password
DB_POOL_SIZE=10

# ─── Redis (rate limiting + job queue) ────────────────
REDIS_URL=redis://localhost:6379

# ─── Microservice URLs (Docker internal networking) ───
COMMENT_SVC_URL=http://comment-svc:3001
LEAD_SVC_URL=http://lead-svc:3002
ANALYTICS_SVC_URL=http://analytics-svc:3003
MODERATION_SVC_URL=http://moderation-svc:3004
REPLY_SVC_URL=http://reply-svc:3005

# ─── Firebase Frontend Config ─────────────────────────
# Used by the frontend (injected at setup time by generate-config.sh)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxx
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Firebase Admin SDK ───────────────────────────────
# Path to Firebase Admin service account JSON file
# In Docker, this is mounted as a secret: /run/secrets/firebase_admin_key
FIREBASE_ADMIN_KEY_PATH=/run/secrets/firebase_admin_key

# Alternative: paste the JSON directly (not recommended)
# FIREBASE_ADMIN_KEY={"type":"service_account",...}

# Alternative: use GOOGLE_APPLICATION_CREDENTIALS
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ─── Encryption (PII protection) ──────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ─── JWT (inter-service auth) ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# ─── OpenRouter metadata ──────────────────────────────
SITE_URL=http://localhost
SITE_NAME=CommentFlow

# ─── Application ──────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=commentflow
FRONTEND_URL=http://localhost:80
DEV_SKIP_AUTH=true

# ─── Dev User (used when DEV_SKIP_AUTH=true) ──────────
DEV_USER_ID=dev-user-id
DEV_USER_EMAIL=dev@example.com
DEV_USER_NAME="Dev User"

# ─── Notification webhooks ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
N8N_WEBHOOK_URL=
CRM_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_URL=
SMTP_WEBHOOK_URL=

# ─── Logging ──────────────────────────────────────────
LOG_QUERIES=false
