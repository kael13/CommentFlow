# ═══════════════════════════════════════════════════════
# CommentFlow — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — only .env.example is tracked.
# ═══════════════════════════════════════════════════════

# ─── OpenRouter LLM API ───────────────────────────────
# Get your API key at: https://openrouter.ai/keys
# Models: https://openrouter.ai/models
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_FALLBACK_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_MAX_RETRIES=3
LLM_RATE_LIMIT_RPM=20
LLM_JOB_TIMEOUT_MS=30000

# ─── PostgreSQL Database ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=commentflow
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_POOL_SIZE=10

# ─── Redis (rate limiting + job queue) ────────────────
REDIS_URL=redis://localhost:6379

# ─── Microservice URLs (Docker internal networking) ───
COMMENT_SVC_URL=http://comment-svc:3001
LEAD_SVC_URL=http://lead-svc:3002
ANALYTICS_SVC_URL=http://analytics-svc:3003
MODERATION_SVC_URL=http://moderation-svc:3004
REPLY_SVC_URL=http://reply-svc:3005

# ─── Notification webhooks ────────────────────────────
# Telegram Bot: https://core.telegram.org/bots
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# n8n automation: https://n8n.io
N8N_WEBHOOK_URL=

# CRM integration webhook
CRM_WEBHOOK_URL=

# Google Sheets webhook (via n8n or Apps Script)
GOOGLE_SHEETS_WEBHOOK_URL=

# SMTP email webhook (via n8n or SendGrid/Mailgun)
SMTP_WEBHOOK_URL=

# ─── Firebase Admin SDK ───────────────────────────────
# Path to Firebase Admin service account JSON file
# In Docker, this is mounted as a secret:
#   /run/secrets/firebase_admin_key
FIREBASE_ADMIN_KEY_PATH=/run/secrets/firebase_admin_key

# Alternative: paste the JSON directly (not recommended)
# FIREBASE_ADMIN_KEY={"type":"service_account",...}

# Alternative: use GOOGLE_APPLICATION_CREDENTIALS
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ─── Encryption (PII protection) ──────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ─── JWT (inter-service auth) ─────────────────────────
JWT_SECRET=your-jwt-secret-here

# ─── OpenRouter metadata ──────────────────────────────
# Used for OpenRouter HTTP-Referer and X-Title headers
SITE_URL=http://localhost
SITE_NAME=CommentFlow

# ─── Application ──────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=commentflow
FRONTEND_URL=http://localhost:80

# ─── Logging ──────────────────────────────────────────
# Set to "true" to log all SQL queries (dev only)
LOG_QUERIES=false
